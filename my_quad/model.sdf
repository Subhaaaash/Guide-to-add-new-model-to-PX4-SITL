<?xml version="1.0" encoding="UTF-8"?>
<sdf version='1.9'>
  <model name='my_quad'>
    <pose>0 0 0 0 0 0</pose>
    <self_collide>false</self_collide>
    <static>false</static>

    <!-- ===== BASE LINK ===== -->
    <link name="base_link">
      <gravity>true</gravity>
      <velocity_decay />

      <!-- *** REPLACE mass and inertia with your CAD values (Tools > Mass Properties) *** -->
      <inertial>
        <mass>0.8</mass>
        <inertia>
          <ixx>0.004</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.004</iyy>
          <iyz>0</iyz>
          <izz>0.007</izz>
        </inertia>
      </inertial>

      <!-- Visual mesh: full frame body -->
      <visual name="base_link_visual">
        <pose>0 0 0.10 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://my_quad/meshes/fpv_quad.dae</uri>
          </mesh>
        </geometry>
      </visual>

      <!-- Collision: simple box approximation -->
      <!-- *** REPLACE size with your actual frame bounding dimensions *** -->
      <collision name="base_link_collision">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>0.35 0.35 0.05</size>
          </box>
        </geometry>
        <surface>
          <contact>
            <ode>
              <min_depth>0.001</min_depth>
              <max_vel>0</max_vel>
            </ode>
          </contact>
          <friction>
            <ode />
          </friction>
        </surface>
      </collision>

      <!-- Barometer -->
      <sensor name="air_pressure_sensor" type="air_pressure">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>50</update_rate>
        <air_pressure>
          <pressure>
            <noise type="gaussian">
              <mean>0</mean>
              <stddev>3</stddev>
            </noise>
          </pressure>
        </air_pressure>
      </sensor>

      <!-- Magnetometer -->
      <sensor name="magnetometer_sensor" type="magnetometer">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>100</update_rate>
        <magnetometer>
          <x>
            <noise type="gaussian">
              <stddev>0.0001</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <stddev>0.0001</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <stddev>0.0001</stddev>
            </noise>
          </z>
        </magnetometer>
      </sensor>

      <!-- IMU -->
      <sensor name="imu_sensor" type="imu">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>250</update_rate>
        <imu>
          <angular_velocity>
            <x>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.0008726646</stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.0008726646</stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.0008726646</stddev>
              </noise>
            </z>
          </angular_velocity>
          <linear_acceleration>
            <x>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.00637</stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.00637</stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.00686</stddev>
              </noise>
            </z>
          </linear_acceleration>
        </imu>
      </sensor>

      <!-- GPS -->
      <sensor name="navsat_sensor" type="navsat">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
      </sensor>

    </link>

    <!-- ===== ROTORS ===== -->
    <!-- Motor positions verified from airframe config: X=0.13, Y=0.22 -->
    <!-- *** REPLACE pose XY/Z with your verified CAD measurements if different *** -->

    <!-- Motor 0: Front-Right (CCW) -->
    <link name="rotor_0">
      <gravity>true</gravity>
      <self_collide>false</self_collide>
      <velocity_decay />
      <pose>0.075 0.075 0 0 0 0</pose>
      <inertial>
        <mass>0.006076923076923075</mass>
        <inertia>
          <ixx>3.8464910483993325e-07</ixx>
          <iyy>2.6115851691700804e-05</iyy>
          <izz>2.649858234714004e-05</izz>
        </inertia>
      </inertial>

      <visual name="rotor_0_visual">
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://my_quad/meshes/propeller_ccw.dae</uri>
          </mesh>
        </geometry>
        <material>
          <ambient> 0 0 1 1</ambient>
          <diffuse>0 0 1 1</diffuse>
          <specular>0 0 0.5 1</specular>
        </material>
      </visual>
      <collision name="rotor_0_collision">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>0.24 0.017 0.001</size>
          </box>
        </geometry>
        <surface>
          <contact>
            <ode>
              <min_depth>0.001</min_depth>
              <max_vel>0</max_vel>
            </ode>
          </contact>
          <friction>
            <ode />
          </friction>
        </surface>
      </collision>
    </link>

    <joint name="rotor_0_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_0</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>

    <!-- Motor 1: Back-Left (CCW) -->
    <link name="rotor_1">
      <gravity>true</gravity>
      <self_collide>false</self_collide>
      <velocity_decay />
      <pose>-0.075 -0.075 0 0 0 0</pose>
      <inertial>
        <mass>0.006076923076923075</mass>
        <inertia>
          <ixx>3.8464910483993325e-07</ixx>
          <iyy>2.6115851691700804e-05</iyy>
          <izz>2.649858234714004e-05</izz>
        </inertia>
      </inertial>
      <visual name="rotor_1_visual">

        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://my_quad/meshes/propeller_ccw.dae</uri>
          </mesh>
        </geometry>
        <material>
          <ambient> 0 0 1 1</ambient>
          <diffuse>0 0 1 1</diffuse>
          <specular>0 0 0.5 1</specular>
        </material>

      </visual>
      <collision name="rotor_1_collision">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>0.24 0.017 0.001</size>
          </box>
        </geometry>

        <surface>
          <contact>
            <ode>
              <min_depth>0.001</min_depth>
              <max_vel>0</max_vel>
            </ode>
          </contact>
          <friction>
            <ode />
          </friction>
        </surface>
      </collision>
    </link>

    <joint name="rotor_1_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_1</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>

    <!-- Motor 2: Front-Left (CW) -->
    <link name="rotor_2">
      <gravity>true</gravity>
      <self_collide>false</self_collide>
      <velocity_decay />
      <pose>0.075 -0.075 0 0 0 0</pose>
      <inertial>
        <mass>0.006076923076923075</mass>
        <inertia>
          <ixx>3.8464910483993325e-07</ixx>
          <iyy>2.6115851691700804e-05</iyy>
          <izz>2.649858234714004e-05</izz>
        </inertia>
      </inertial>
      <visual name="rotor_2_visual">

        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://my_quad/meshes/propeller_cw.dae</uri>
          </mesh>
        </geometry>
        <material>
          <ambient> 0 0 1 1</ambient>
          <diffuse>0 0 1 1</diffuse>
          <specular>0 0 0.5 1</specular>
        </material>
      </visual>
      <collision name="rotor_2_collision">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>0.24 0.017 0.001</size>
          </box>
        </geometry>
        <surface>
          <contact>
            <ode>
              <min_depth>0.001</min_depth>
              <max_vel>0</max_vel>
            </ode>
          </contact>
          <friction>
            <ode />
          </friction>
        </surface>
      </collision>
    </link>

    <joint name="rotor_2_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_2</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>

    <!-- Motor 3: Back-Right (CW) -->
    <link name="rotor_3">
      <gravity>true</gravity>
      <self_collide>false</self_collide>
      <velocity_decay />
      <pose>-0.075 0.075 0 0 0 0</pose>
      <inertial>
        <mass>0.006076923076923075</mass>
        <inertia>
          <ixx>3.8464910483993325e-07</ixx>
          <iyy>2.6115851691700804e-05</iyy>
          <izz>2.649858234714004e-05</izz>
        </inertia>
      </inertial>
      <visual name="rotor_3_visual">

        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://my_quad/meshes/propeller_cw.dae</uri>
          </mesh>
        </geometry>
        <material>
          <ambient> 0 0 1 1</ambient>
          <diffuse>0 0 1 1</diffuse>
          <specular>0 0 0.5 1</specular>
        </material>
      </visual>
      <collision name="rotor_3_collision">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>0.24 0.017 0.001</size>
          </box>
        </geometry>
        <surface>
          <contact>
            <ode>
              <min_depth>0.001</min_depth>
              <max_vel>0</max_vel>
            </ode>
          </contact>
          <friction>
            <ode />
          </friction>
        </surface>
      </collision>
    </link>

    <joint name="rotor_3_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_3</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>

    <!-- ===== PLUGINS ===== -->
    <!-- NOTE: Sensor system plugins (Imu, Magnetometer, AirPressure, NavSat)
         are loaded globally via server.config — do NOT add them here. -->

    <!-- Motor 0: Front-Right (CCW) -->
    <plugin filename="gz-sim-multicopter-motor-model-system"
            name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_0_joint</jointName>
      <linkName>rotor_0</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.025</timeConstantUp>
      <timeConstantDown>0.05</timeConstantDown>
      <maxRotVelocity>2618.0</maxRotVelocity>
      <motorConstant>1.269e-05</motorConstant>
      <momentConstant>0.002</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>0</motorNumber>
      <rotorDragCoefficient>1.0e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>

    <!-- Motor 1: Back-Left (CCW) -->
    <plugin filename="gz-sim-multicopter-motor-model-system"
            name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_1_joint</jointName>
      <linkName>rotor_1</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.025</timeConstantUp>
      <timeConstantDown>0.05</timeConstantDown>
      <maxRotVelocity>2618.0</maxRotVelocity>
      <motorConstant>1.269e-05</motorConstant>
      <momentConstant>0.002</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>1</motorNumber>
      <rotorDragCoefficient>1.0e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>

    <!-- Motor 2: Front-Left (CW) -->
    <plugin filename="gz-sim-multicopter-motor-model-system"
            name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_2_joint</jointName>
      <linkName>rotor_2</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.025</timeConstantUp>
      <timeConstantDown>0.05</timeConstantDown>
      <maxRotVelocity>2618.0</maxRotVelocity>
      <motorConstant>1.269e-05</motorConstant>
      <momentConstant>0.002</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>2</motorNumber>
      <rotorDragCoefficient>1.0e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>

    <!-- Motor 3: Back-Right (CW) -->
    <plugin filename="gz-sim-multicopter-motor-model-system"
            name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_3_joint</jointName>
      <linkName>rotor_3</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.025</timeConstantUp>
      <timeConstantDown>0.05</timeConstantDown>
      <maxRotVelocity>2618.0</maxRotVelocity>
      <motorConstant>1.269e-05</motorConstant>
      <momentConstant>0.002</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>3</motorNumber>
      <rotorDragCoefficient>1.0e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>

  </model>
</sdf>
